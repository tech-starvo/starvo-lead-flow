# Supabase (copy to .env and fill in)
# Local: use http://127.0.0.1:54321 and anon key from `supabase status` after `supabase start`
# Production: use project URL and anon key from Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: static admin token for leads API (no Firebase custom claims / Blaze needed).
# Set the same value as ADMIN_TOKEN in Supabase Edge Function secrets (admin-leads).
# If set, admin data is fetched with this token instead of the Firebase ID token.
# VITE_ADMIN_TOKEN=

# Firebase (for Google sign-in)
# Get from Firebase Console → Project Settings → General → Your apps → Web app config
# Enable Google sign-in: Authentication → Sign-in method → Google → Enable
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
